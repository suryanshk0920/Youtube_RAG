# Get this free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get this free at https://console.cloud.google.com
# Enable YouTube Data API v3, then create credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Get this at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use via OpenRouter (default: openrouter/auto, free tier: openrouter/free)
OPENROUTER_MODEL=openrouter/auto

# LLM provider: "openrouter" or "gemini"
LLM_PROVIDER=openrouter

# CORS — comma-separated list of allowed origins for the API
# Use * for development, set your Next.js domain in production
ALLOWED_ORIGINS=*
DATA_DIR=./data
CHROMA_DIR=./data/chromadb
